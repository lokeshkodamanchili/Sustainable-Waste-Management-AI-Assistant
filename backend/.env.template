# Flask configuration
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# Groq API configuration
GROQ_API_KEY=your_groq_api_key_here

# Firebase Admin configuration
# Set to 'true' to use Firebase, otherwise it defaults to local JSON storage
USE_FIREBASE=false
# If USE_FIREBASE=true, provide path to Firebase Service Account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=path/to/serviceAccountKey.json
# Or provide the JSON string directly
FIREBASE_CREDENTIALS_JSON=
# Firebase project ID
FIREBASE_PROJECT_ID=
